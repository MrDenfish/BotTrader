VERSION=6.0.0
############################################################
# BotTrader — Unified Configuration Template
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.template .env
# 2. Fill in all values marked with YOUR_* placeholders
# 3. Never commit .env to git (it contains secrets)
#
# This single .env file works for both desktop and Docker environments.
# Runtime detection automatically configures environment-specific values:
#   - DB_HOST: Computed at runtime (127.0.0.1 for desktop, 'db' for Docker)
#   - WEBHOOK_BASE_URL: Computed at runtime based on environment
#   - Log paths: Computed at runtime based on environment
#   - IN_DOCKER flag: Auto-detected via filesystem checks
############################################################

# ---------- Core ----------
ENV=prod
VERSION=6.0.0
TZ=America/Los_Angeles
LOG_LEVEL=INFO

# Note: IN_DOCKER and IS_DOCKER are auto-detected at runtime
# Desktop: Auto-detects as false
# Docker: Auto-detects as true via /.dockerenv or /proc/1/cgroup

# ---------- Debugging ----------
BT_WATCHDOG=1
BT_TASK_CENSUS=0
BT_DEBUG_AIO=0
BT_STACK_LOG=/tmp/py-stacks.log
BT_DB_POOL_TIMEOUT_S=5
BT_DB_STMT_TIMEOUT_MS=15000

# ---------- Database ----------
# Note: DB_HOST is auto-computed at runtime:
#   - Desktop: 127.0.0.1
#   - Docker: db (service name from docker-compose)
# You can override by setting DB_HOST explicitly if needed

DB_PORT=5432
DB_NAME=bot_trader_db
DB_USER=bot_user
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE
DB_MONITOR_INTERVAL=10
DB_CONNECTION_THRESHOLD=25
DB_ECHO_POOL=false

# ---------- AWS / SES (boto3) ----------
AWS_REGION=us-west-2
# Report email (SES API, not SMTP)
REPORT_SENDER=YOUR_EMAIL_FROM@example.com
REPORT_RECIPIENTS=YOUR_EMAIL_TO@example.com

# ---------- Email (legacy/disabled) ----------
# EMAIL_PROVIDER=ses     # (unused; code uses boto3 SES client)
SMTP_SERVER=email-smtp.us-west-2.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_SMTP_USERNAME_HERE
SMTP_PASSWORD=YOUR_SMTP_PASSWORD_HERE
SMTP_USE_TLS=true

# ---------- Service wiring / URLs ----------
# Note: WEBHOOK_BASE_URL is auto-computed at runtime:
#   - Desktop: Uses PC_URL or can be set via WEBHOOK_BASE_URL env var
#   - Docker: http://webhook:5003 (service name from docker-compose)
# To override for desktop dev with ngrok, set WEBHOOK_BASE_URL in your shell

WEBHOOK_PATH=/webhook
WEBHOOK_PORT=5003
WEBHOOK_TOKEN=YOUR_SECURE_RANDOM_TOKEN_HERE
PC_URL=https://pro.coinbase.com

# --- IP lists ---
# Add your allowed IPs: desktop IP, server IP, ngrok IPs, docker subnet, etc.
COIN_WHITELIST=127.0.0.1,127.0.1.1,172.18.0.0/16

# ---------- Alerts ----------
ALERT_EMAIL=YOUR_ALERT_EMAIL@example.com
ALERT_PHONE=YOUR_PHONE_NUMBER_HERE
ACCOUNT_PHONE=YOUR_PHONE_NUMBER_HERE

# ---------- Exchange/API keys ----------
API_KEY_SIGHOOK=/app/sighook_api_key.json
API_KEY_WEBHOOK=/app/webhook_api_key.json
API_KEY_TB=/app/tb_api_key.json
API_KEY_WEBSOCKET=/app/websocket_api_key.json

# ---------- Trading config ----------
SLEEP=300
CURRENCY_PAIRS_IGNORED=USD/USD,USDT/USDC,USDC/USDC,USDC/USD,USDT/USD,UNFI/USD,UNFI/USDT,UNFI/USDC,UNFI/BTC,UNFI/ETH,UNFI/BNB
QUOTE_CURRENCY=USD
MIN_COOLDOWN=5
STOP_MODE=atr
# stop = max(STOP_ATR_MULT * ATR%, STOP_MIN_PCT) + cushions
ATR_MULTIPLIER_STOP=1.8
# floor when ATR is tiny (1.2%)
STOP_MIN_PCT=0.012
# 0.15% extra if unable to read the live spread
SPREAD_CUSHION_PCT=0.0015
SPREAD_TO_FEE_MIN=2.0
TP_MIN_TICKS=3
SL_LIMIT_OFFSET_TICKS=2
MIN_L1_NOTIONAL_USD=250
PREBRACKET_SIGMA_RATIO=1

FEE_SIDE=taker
TAKER_FEE=0.0055
MAKER_FEE=0.003

MIN_QUOTE_VOLUME=2000000
MIN_ORDER_AMOUNT_FIAT=5
ORDER_SIZE_FIAT=60
MIN_SELL_VALUE=1.01
MAX_OHLCV_ROWS=1440
CXL_BUY=0.01
CXL_SELL=0.01
MIN_VALUE_TO_MONITOR=1.01

# --- Scoring targets (sum of indicator weights) ---
SCORE_BUY_TARGET=5.5
SCORE_SELL_TARGET=5.5
SCORE_LOG_PATH=/dev/null

# --- Optional guardrails ---
# if false, a red 24h day can block buys even if score passes
ALLOW_BUYS_ON_RED_DAY=true
# require +10% over target to flip sides
FLIP_HYSTERESIS_PCT=0.10
# bars to ignore the opposite side after a flip
COOLDOWN_BARS=7

# ---------- Trading parameters ----------
SHILL_COINS=UNFI,TRUMP,MATIC
HODL=ATOM,ETH
BUY_RATIO=1.05
SELL_RATIO=0.95
ENRICH_LIMIT=20
MIN_BUY_VALUE=10
MIN_SELL_VALUE=10
MAX_VALUE_TO_BUY=250
# past ATR values: 10
ATR_WINDOW=8
BB_WINDOW=10
BB_STD=2
BB_LOWER_BAND=1.0
BB_UPPER_BAND=1.1
MACD_FAST=8
MACD_SLOW=21
MACD_SIGNAL=5
RSI_WINDOW=7
RSI_OVERBOUGHT=75
RSI_OVERSOLD=25
SMA_FAST=10
SMA_SLOW=30
SMA=15
SMA_VOLATILITY=10
SWING_WINDOW=10
ROC_WINDOW=5
ROC_5MIN=2
ROC_BUY_24H=2
ROC_SELL_24H=1
STOP_LOSS=-0.01
TAKE_PROFIT=0.025
TRAILING_STOP=0.02
TRAILING_PERCENTAGE=0.02
TRAILING_LIMIT=0.02

# ---------- Passive Order Parameters ----------
EDGE_BUFFER_PCT=0.00005
MIN_SPREAD_PCT=0.00025
PASSIVE_IGNORE_FEES_FOR_SPREAD=false
MAX_LIFETIME=600
INVENTORY_BIAS_FACTOR=0.10

# ---------- Logging / Paths ----------
# Note: Log paths are auto-computed at runtime:
#   - Desktop: Uses .bottrader/cache/ or /tmp/
#   - Docker: /app/logs/
# SCORE_JSONL_PATH and TP_SL_LOG_PATH are set by config_manager.py

LOG_DIR=/app/logs
UTILS_DIR=/app/utils
MACHINE_HOST1=webhook
MACHINE_HOST2=sighook

# ---------- Report table column labels (used by aws_daily_report.py) ----------
REPORT_PNL_TABLE=public.trade_records
REPORT_EXECUTIONS_TABLE=public.trade_records
REPORT_PRICE_TABLE=public.trade_records
REPORT_PRICE_COL=price
REPORT_PRICE_TIME_COL=order_time
REPORT_PRICE_SYM_COL=symbol
# 0 = overview-only; 1 = include tables
REPORT_SHOW_DETAILS=0
REPORT_WINRATE_TABLE=public.trade_records
REPORT_POSITIONS_TABLE=public.trade_records
REPORT_TRADES_TABLE=public.trade_records
REPORT_LOOKBACK_HOURS=24
REPORT_LOOKBACK_MINUTES=1440
REPORT_DEBUG=0

# --- column mappings ---
REPORT_COL_SYMBOL=symbol
REPORT_COL_SIDE=side
REPORT_COL_PRICE=price
REPORT_COL_SIZE=size
REPORT_COL_TIME=order_time
REPORT_COL_POS_QTY=position_qty
REPORT_COL_PNL=realized_profit

# ---------- Misc ----------
FIFO_FORCE_SYMBOLS=TOSHI-USD
